# Nest API (server-side rewrite target)
API_INTERNAL_URL=http://localhost:3000

# Public URL của web app (CORS trên Nest dùng WEB_ORIGIN khớp giá trị này)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ---- Production (Vercel) ----
# Điền thẳng vào ô "Environment Variables" trên Vercel project settings, không dùng file .env.
# API_INTERNAL_URL=<domain Render thật, vd https://ten-du-an-api.onrender.com>
# NEXT_PUBLIC_APP_URL=<domain Vercel thật, vd https://ten-du-an.vercel.app>
