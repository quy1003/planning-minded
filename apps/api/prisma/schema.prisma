// apps/api/prisma/schema.prisma
// Phase 1 modular monolith: User + Trip domain trong cùng 1 DB.
// userId trên Trip không FK (chuẩn bị tách auth_db sau — docs/06-database-schema.md).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  avatarUrl    String?
  preferences  Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

enum TripStatus {
  DRAFT
  PLANNED
  COMPLETED
}

enum DaySlot {
  MORNING
  AFTERNOON
  EVENING
}

model Trip {
  id              String     @id @default(uuid())
  userId          String
  title           String
  destinationName String
  startDate       DateTime?  @db.Date
  days            Int
  partySize       Int
  budget          Decimal    @db.Decimal(12, 2)
  currency        String     @default("VND") @db.Char(3)
  status          TripStatus @default(DRAFT)
  aiSessionId     String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  places         Place[]
  itineraryItems ItineraryItem[]

  @@index([userId, status])
  @@map("trips")
}

model Place {
  id             String   @id @default(uuid())
  tripId         String
  trip           Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  name           String
  address        String?
  lat            Decimal  @db.Decimal(9, 6)
  lng            Decimal  @db.Decimal(9, 6)
  catalogPlaceId String?
  createdAt      DateTime @default(now())

  itineraryItems ItineraryItem[]

  @@index([tripId])
  @@map("places")
}

model ItineraryItem {
  id      String @id @default(uuid())
  tripId  String
  trip    Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  placeId String
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Restrict)

  dayNumber Int
  slot      DaySlot
  visitOrder Int

  startTime   DateTime? @db.Time
  endTime     DateTime? @db.Time
  durationMin Int?

  title       String
  description String?
  estCost     Decimal  @default(0) @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tripId, dayNumber, slot, visitOrder])
  @@index([tripId, dayNumber])
  @@map("itinerary_items")
}
