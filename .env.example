PORT=3000
DATABASE_URL=postgresql://tripmind:tripmind@localhost:5433/tripmind
REDIS_URL=redis://localhost:6379
# Dev-only placeholder — dùng chuỗi random dài (vd `openssl rand -hex 32`) cho môi trường thật, không commit giá trị thật.
SESSION_SECRET=dev-only-change-me-use-a-long-random-string
# Origin Next.js web (CORS). Khớp NEXT_PUBLIC_APP_URL ở apps/web.
WEB_ORIGIN=http://localhost:3001

# ---- Production (Render) ----
# KHÔNG dùng file .env trên Render — điền các biến dưới đây thẳng vào ô "Environment" trên
# dashboard Render, không commit giá trị thật vào repo. Xem docs/learning/35-deploy-plan.md.
# NODE_ENV=production
# DATABASE_URL=<connection string từ Neon>
# REDIS_URL=<connection string từ Upstash — dạng redis:// hoặc rediss://, KHÔNG lấy REST URL>
# SESSION_SECRET=<tạo bằng lệnh `openssl rand -hex 32` — không dùng lại giá trị dev-only ở trên>
# WEB_ORIGIN=<domain Vercel thật, vd https://ten-du-an.vercel.app>
# PORT không cần điền — Render tự set qua biến môi trường riêng của họ.
